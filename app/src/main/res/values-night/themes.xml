<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.AllerSafe" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/bg_main</item>

        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorPrimaryVariant">@color/accent_primary</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSurface">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>

        <item name="dynamicCardElevation">0dp</item>

        <item name="popupMenuStyle">@style/MinimalistPopupMenu</item>
        <item name="android:popupMenuStyle">@style/MinimalistPopupMenu</item>
        <item name="android:fontFamily">@font/chopra_expanded</item>
        <item name="fontFamily">@font/chopra_expanded</item>
    </style>

    <style name="MinimalistPopupMenu" parent="Widget.MaterialComponents.PopupMenu">
        <item name="android:popupBackground">@drawable/bg_rounded_menu</item>
        <item name="android:popupElevation">8dp</item>
        <item name="android:dropDownSelector">?attr/selectableItemBackground</item>
        <item name="android:divider">@null</item>
    </style>

    <style name="ShapeAppearanceOverlay.App.CornerSize50Percent" parent="">
        <item name="cornerSize">50%</item>
    </style>

    <style name="ShapeAppearanceOverlay.App.CornerSize10Percent" parent="">
        <item name="cornerSize">10%</item>
    </style>
</resources>